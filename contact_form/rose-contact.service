[Unit]
Description=Rose Medical Contact Form Handler
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/var/www/rose-medical/contact_form
EnvironmentFile=/etc/rose-contact.env
ExecStart=/var/www/rose-medical/contact_form/venv/bin/gunicorn -w 2 -b 127.0.0.1:5001 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
